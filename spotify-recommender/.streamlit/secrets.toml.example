# Copy to .streamlit/secrets.toml for local use, or paste these into
# Streamlit Community Cloud → App → Settings → Secrets.
SPOTIFY_CLIENT_ID = "your_client_id"
SPOTIFY_CLIENT_SECRET = "your_client_secret"

